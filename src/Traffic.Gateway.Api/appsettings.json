{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ConsumerGroups": {
      "DecisionEngine": "traffic-decision-engine",
      "Gateway": "traffic-gateway",
      "GatewayMeasurements": "traffic-gateway-measurements",
      "ProducerState": "traffic-producer-state"
    },
    "Topics": {
      "Measurements": "traffic.measurements",
      "Commands": "traffic.commands",
      "State": "traffic.state",
      "Metrics": "traffic.metrics"
    }
  },
  "Database": {
    "ConnectionString": "Host=localhost;Port=5433;Database=traffic_thesis;Username=postgres;Password=postgres"
  },
  "Simulation": {
    "TickMilliseconds": 1000,
    "RandomSeed": 42,
    "Scenario": "Balanced",
    "DepartureRatePerTick": 3,
    "RunDurationSeconds": 30,
    "StopProducerAfterRun": true,
    "ExperimentName": "Balanced-LQF-30s"
  },
  "Policy": {
    "Mode": "LongestQueueFirst",
    "FixedTime": {
      "GreenSeconds": 10,
      "YellowSeconds": 3
    },
    "LongestQueueFirst": {
      "MinGreenSeconds": 8,
      "MaxGreenSeconds": 25,
      "YellowSeconds": 3,
      "MaxConsecutiveSelections": 2,
      "FairnessQueueThreshold": 3
    }
  },
  "Topology": {
    "Intersections": [
      {
        "Id": "I1",
        "Name": "Intersection 1",
        "Signals": [
          { "Id": "S1", "Name": "North" },
          { "Id": "S2", "Name": "East" },
          { "Id": "S3", "Name": "South" },
          { "Id": "S4", "Name": "West" }
        ]
      },
      {
        "Id": "I2",
        "Name": "Intersection 2",
        "Signals": [
          { "Id": "S1", "Name": "North" },
          { "Id": "S2", "Name": "East" },
          { "Id": "S3", "Name": "South" }
        ]
      },
      {
        "Id": "I3",
        "Name": "Intersection 3",
        "Signals": [
          { "Id": "S1", "Name": "North" },
          { "Id": "S2", "Name": "East" },
          { "Id": "S3", "Name": "South" },
          { "Id": "S4", "Name": "West" },
          { "Id": "S5", "Name": "Bus Lane" }
        ]
      }
    ]
  }
}
